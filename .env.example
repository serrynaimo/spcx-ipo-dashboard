# ============================================================================
# SPCX IPO Model Explorer — backend config (server-side only, never bundled)
# Copy to ".env" and fill in your key.   cp .env.example .env
# ============================================================================

# Port the Express proxy listens on (Vite dev proxies /api here).
PORT=8787

# ---- Mode -------------------------------------------------------------------
# remote = call the deployed L4 API on Legalese Cloud (needs L4_API_KEY).
# local  = evaluate the .l4 model on disk with the local `l4` CLI (no key,
#          days-only — great for a quick preview before the key is in place).
L4_MODE=remote

# ---- Remote (Legalese Cloud) ------------------------------------------------
L4_API_BASE=https://api.legalese.cloud/legalese
L4_DEPLOYMENT=spacex-ipo-model

# >>> PASTE YOUR API KEY / BEARER TOKEN HERE <<<
L4_API_KEY=

# Auth header scheme. Usually "Bearer". Set to "" to send the raw key,
# or e.g. "Token" if your deployment expects that.
L4_AUTH_SCHEME=Bearer

# Merged range endpoint route (the leading keyword run of the mixfix function
# `the SpaceX SPCX market from day _ to day _ using _`).
L4_FN_MARKET=the-SpaceX-SPCX-market-from-day

# Default-config endpoint route (the `the default SpaceX IPO config` export). The
# dashboard fetches the canonical IPO config from here instead of hardcoding it.
L4_FN_CONFIG=the-default-SpaceX-IPO-config

# ---- Local fallback (only used when L4_MODE=local) --------------------------
L4_BIN=/Users/tgorissen/Sites/l4-ide/dist-newstyle/build/aarch64-osx/ghc-9.10.2/jl4-0.1/x/l4/build/l4/l4
L4_FILE=/Users/tgorissen/Sites/l4-ingest-agent/workspace/SpaceX IPO/spacex-ipo-model.l4

# Frontend (VITE_ = exposed to the browser): link to the deployed model source
VITE_MODEL_CODE_URL=https://jl4.legalese.com/?id=YOUR-DEPLOYMENT-ID
